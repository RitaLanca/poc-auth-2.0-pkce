# =========================
# AUTH0 CONFIGURATION (SPA)
# =========================

# Auth0 domain (issuer base URL)
# Example: https://dev-xxxx.auth0.com
VITE_AUTH0_DOMAIN=

# Client ID of your Auth0 Application (SPA)
# Found in: Auth0 Dashboard → Applications → Your App → Client ID
VITE_AUTH_CLIENT_ID=

# API Identifier (Audience)
# Must match the identifier defined in Auth0 → APIs
# Example: https://my-api
VITE_API_AUDIENCE=

# Base URL of your backend/API (optional, depending on your setup)
# Example: http://localhost:3000
VITE_AUTH0_API=